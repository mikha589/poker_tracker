<div class="min-h-screen p-6 text-slate-200">
  <div class="max-w-6xl mx-auto">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
      <h1 class="text-3xl font-black tracking-widest uppercase text-white">Статистика</h1>
      <div class="bg-blue-600/20 border border-blue-500/50 px-4 py-2 rounded-lg">
        <span class="text-blue-400 text-sm font-bold uppercase tracking-tighter">Текущий стрик:</span>
        <span class="text-white font-black ml-2"><%= @stats.streak_win %></span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      <div class="bg-slate-900/50 border border-slate-800 p-6 rounded-2xl backdrop-blur-sm">
        <p class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Общий профит</p>
        <h2 class="text-4xl font-black <%= @stats.total_profit >= 0 ? 'text-green-400' : 'text-red-500' %>">
          <%= @stats.total_profit %>$
        </h2>
      </div>

      <div class="bg-slate-900/50 border border-slate-800 p-6 rounded-2xl backdrop-blur-sm">
        <p class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Винрейт ($/час)</p>
        <h2 class="text-4xl font-black text-cyan-400"><%= @stats.hourly_rate %>$</h2>
      </div>

      <div class="bg-slate-900/50 border border-slate-800 p-6 rounded-2xl backdrop-blur-sm">
        <p class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-2">Общий ROI</p>
        <% 
          total_buy_in = @sessions.sum { |s| s.buy_in || 0 }
          total_roi = total_buy_in > 0 ? ((@stats.total_profit.to_f / total_buy_in) * 100).round(1) : 0
        %>
        <h2 class="text-4xl font-black text-yellow-500"><%= total_roi %>%</h2>
      </div>
    </div>

    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden mb-10">
      <div class="px-6 py-4 border-b border-slate-800 bg-slate-900/80">
        <h3 class="text-sm font-bold uppercase text-slate-300">По форматам</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="text-slate-500 text-[10px] uppercase tracking-wider border-b border-slate-800">
              <th class="px-6 py-4 font-bold">Формат</th>
              <th class="px-6 py-4 font-bold">Профит</th>
              <th class="px-6 py-4 font-bold">ROI</th>
              <th class="px-6 py-4 font-bold text-right">Почасовка</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800">
            <% @stats.stats_by_format.each do |f| %>
              <tr class="hover:bg-slate-800/30 transition-colors">
                <td class="px-6 py-4 font-bold text-white"><%= f[:name] %></td>
                <td class="px-6 py-4 font-medium <%= f[:profit] >= 0 ? 'text-green-400' : 'text-red-500' %>">
                  <%= f[:profit] %>$
                </td>
                <td class="px-6 py-4 text-slate-300"><%= f[:roi] %>%</td>
                <td class="px-6 py-4 text-right font-mono text-cyan-400"><%= f[:hourly] %>$/ч</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-800 bg-slate-900/80">
        <h3 class="text-sm font-bold uppercase text-slate-300">По локациям</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="text-slate-500 text-[10px] uppercase tracking-wider border-b border-slate-800">
              <th class="px-6 py-4 font-bold">Формат</th>
              <th class="px-6 py-4 font-bold">Локация</th>
              <th class="px-6 py-4 font-bold">Профит</th>
              <th class="px-6 py-4 font-bold text-right">$/час</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800">
            <% @stats.stats_by_format_and_location.each do |row| %>
              <tr class="hover:bg-slate-800/30 transition-colors text-sm">
                <td class="px-6 py-4">
                  <span class="bg-slate-800 text-slate-300 px-2 py-1 rounded text-[10px] font-bold uppercase">
                    <%= row[:format] %>
                  </span>
                </td>
                <td class="px-6 py-4 text-slate-300"><%= row[:location] %></td>
                <td class="px-6 py-4 font-bold <%= row[:profit] >= 0 ? 'text-green-400' : 'text-red-500' %>">
                  <%= row[:profit] %>$
                </td>
                <td class="px-6 py-4 text-right text-cyan-500 font-mono"><%= row[:hourly] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>