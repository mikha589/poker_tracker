<div class="w-full bg-slate-900 min-h-screen text-slate-200 font-sans">
  
  <%# Шапка %>
  <nav class="w-full bg-slate-800 border-b border-slate-700 sticky top-0 z-50 shadow-2xl">
    <div class="max-w-[1400px] mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <%= link_to poker_sessions_path, class: "text-slate-500 hover:text-white transition-all" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke-width="2"></path></svg>
        <% end %>
        <span class="text-2xl font-black text-white tracking-tighter italic uppercase">
          АНАЛИТИКА <span class="text-blue-500">ТЕГОВ</span>
        </span>
      </div>
    </div>
  </nav>

  <main class="max-w-[1400px] mx-auto py-10 px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <% @tags.each do |t| %>
        <%# Карточка без hover-эффектов %>
        <div class="bg-slate-800 border border-slate-700 p-6 rounded-2xl shadow-xl">
          
          <%# Имя тега %>
          <div class="flex items-center gap-2 mb-6">
            <span class="text-blue-500 font-black text-xl">#</span>
            <span class="text-white font-black uppercase tracking-tight text-xl leading-none">
              <%= t.name %>
            </span>
          </div>

          <div class="space-y-4">
            <%# Количество игр %>
            <div class="flex justify-between items-end border-b border-slate-700/50 pb-2">
              <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest text-nowrap">Всего игр</span>
              <span class="text-lg font-mono font-bold text-slate-200">
                <%= t.poker_sessions.count %>
              </span>
            </div>

            <%# Средний профит %>
            <div class="flex justify-between items-end">
              <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest text-nowrap">Ср. Профит</span>
              <span class="text-2xl font-mono font-black">
                <% if t.poker_sessions.any? %>
                  <% avg = t.poker_sessions.average('cashout - buy_in') %>
                  <span class="<%= avg >= 0 ? 'text-green-400' : 'text-red-400' %>">
                    <%= number_with_precision(avg, precision: 1) %>$
                  </span>
                <% else %>
                  <span class="text-slate-600">0$</span>
                <% end %>
              </span>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @tags.empty? %>
      <div class="py-32 text-center">
        <div class="text-4xl mb-4 opacity-10 uppercase font-black italic">No Tags Found</div>
        <p class="text-slate-600 text-sm tracking-widest uppercase">Добавь теги в сессиях, чтобы увидеть их здесь</p>
      </div>
    <% end %>
  </main>
</div>