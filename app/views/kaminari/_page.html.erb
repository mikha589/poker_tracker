<% if page.current? %>
  <span class="px-4 py-2 text-sm font-bold text-white bg-blue-600 rounded-md shadow-sm">
    <%= page %>
  </span>
<% else %>
  <%= link_to page, url, { remote: remote, rel: page.rel, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" } %>
<% end %>