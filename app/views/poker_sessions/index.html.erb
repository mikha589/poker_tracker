<div class="w-full bg-slate-900 min-h-screen text-slate-200 font-sans">
  
  <nav class="w-full bg-slate-800 border-b border-slate-700 sticky top-0 z-50 shadow-2xl">
    <div class="max-w-[1400px] mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-10">
        <span class="text-2xl font-black text-white tracking-tighter italic">
          POKER<span class="text-blue-500">TRACKER</span>
        </span>
        
        <div class="hidden lg:flex items-center gap-3">
          <div class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 flex items-center gap-3 cursor-not-allowed opacity-60">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Фильтр:</span>
            <span class="text-xs text-slate-300">Все игры</span>
            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2"></path></svg>
          </div>
        </div>
      </div>

      <%= link_to new_poker_session_path, class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-black px-6 py-2.5 rounded-lg transition-all flex items-center gap-2 shadow-lg shadow-blue-900/40 active:scale-95 uppercase tracking-wider" do %>
        <span class="text-xl leading-none">+</span> Новая сессия
      <% end %>
    </div>
  </nav>

  <main class="max-w-[1400px] mx-auto py-10 px-6">
    
    <div class="overflow-hidden bg-slate-800 rounded-xl border border-slate-700 shadow-2xl">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-900/60 text-slate-500 text-[11px] uppercase tracking-[0.2em] font-bold">
            <th class="p-6">Дата и формат</th>
            <th class="p-6">Место проведения</th>
            <th class="p-6">Лимит</th>
            <th class="p-6">Профит</th>
            <th class="p-6 text-right">Управление</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-700/50">
          <% @poker_sessions.each do |session| %>
            <% profit = (session.cashout || 0) - (session.buy_in || 0) %>
            <tr class="hover:bg-blue-500/5 transition-colors group">
              <td class="p-6">
                <div class="text-base font-bold text-slate-100"><%= session.date.strftime("%d.%m.%Y") %></div>
                <div class="text-xs text-blue-400 font-medium uppercase tracking-tight mt-1"><%= session.game_format %></div>
              </td>
              <td class="p-6 text-base text-slate-300">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-slate-600"></span>
                  <%= session.location %>
                </div>
              </td>
              <td class="p-6">
                <span class="bg-slate-900/80 px-3 py-1.5 rounded-md text-xs font-mono text-slate-400 border border-slate-700">
                  <%= session.limit %>
                </span>
              </td>
              <td class="p-6">
                <div class="text-xl font-mono font-black <%= profit >= 0 ? 'text-green-400' : 'text-red-400' %>">
                  <%= profit >= 0 ? "+$#{profit}" : "-$#{profit.abs}" %>
                </div>
                <div class="text-[10px] text-slate-500 uppercase mt-1">
                   Buy-in: $<%= session.buy_in %>
                </div>
              </td>
              <td class="p-6">
                <div class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                  <%= link_to "Детали", session, class: "text-[10px] font-bold uppercase tracking-widest bg-slate-700 hover:bg-slate-600 text-slate-200 px-4 py-2 rounded-md transition" %>
                  <%= link_to "Правка", edit_poker_session_path(session), class: "text-[10px] font-bold uppercase tracking-widest bg-slate-700 hover:bg-blue-600 text-slate-200 px-4 py-2 rounded-md transition" %>
                  <%= link_to "Удалить", session, data: { turbo_method: :delete, turbo_confirm: "Удалить сессию?" }, class: "text-[10px] font-bold uppercase tracking-widest bg-slate-900 hover:bg-red-600 text-red-500 hover:text-white px-4 py-2 rounded-md transition" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <% if @poker_sessions.empty? %>
        <div class="py-32 text-center">
          <div class="text-6xl mb-6 opacity-20 text-blue-500">♠️</div>
          <p class="text-slate-500 font-medium tracking-wide">Список пуст. Пора зайти в игру!</p>
        </div>
      <% end %>
    </div>
  </main>

</div>