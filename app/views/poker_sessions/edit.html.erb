<div class="w-full min-h-screen bg-slate-900 pt-10 pb-20 px-4 text-slate-200">
  <div class="max-w-lg mx-auto bg-slate-800 p-8 rounded-2xl border border-slate-700 shadow-2xl">
    
    <div class="flex items-center justify-between mb-8">
      <%= link_to "← Назад", poker_sessions_path, class: "text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-blue-400 transition" %>
      <h2 class="text-xl font-black text-white text-center uppercase tracking-tighter">
        Правка <span class="text-blue-500">сессии</span>
      </h2>
      <div class="w-10"></div> </div>

    <%= form_with(model: @poker_session, local: true, class: "space-y-5") do |f| %>
      <div>
        <%= f.label :date, "Дата", class: "text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1 block" %>
        <%= f.date_field :date, class: "w-full bg-slate-900 border border-slate-700 rounded-xl text-white p-3 focus:ring-2 focus:ring-blue-500 outline-none transition" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :location, "Локация", class: "text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1 block" %>
          <%= f.text_field :location, class: "w-full bg-slate-900 border border-slate-700 rounded-xl text-white p-3" %>
        </div>
        <div>
          <%= f.label :game_format, "Формат", class: "text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1 block" %>
          <%= f.text_field :game_format, class: "w-full bg-slate-900 border border-slate-700 rounded-xl text-white p-3" %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :buy_in, "Бай-ин ($)", class: "text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1 block" %>
          <%= f.number_field :buy_in, class: "w-full bg-slate-900 border border-slate-700 rounded-xl text-white p-3 font-bold" %>
        </div>
        <div>
          <%= f.label :cashout, "Кэшаут ($)", class: "text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1 block" %>
          <%= f.number_field :cashout, class: "w-full bg-slate-900 border border-slate-700 rounded-xl text-green-400 p-3 font-bold" %>
        </div>
      </div>

      <div>
        <%= f.label :notes, "Заметки", class: "text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1 block" %>
        <%= f.text_area :notes, rows: 3, class: "w-full bg-slate-900 border border-slate-700 rounded-xl text-white p-3 resize-none" %>
      </div>

      <div class="pt-4">
        <%= f.submit "ОБНОВИТЬ ДАННЫЕ", class: "w-full bg-blue-600 hover:bg-blue-500 text-white font-black py-4 rounded-xl shadow-lg shadow-blue-900/30 transition-all active:scale-95 cursor-pointer uppercase tracking-widest text-sm" %>
      </div>
    <% end %>
  </div>
</div>