<%
  def login_input_class(field)
    base_classes = "appearance-none block w-full px-4 py-3.5 border bg-slate-900 text-white rounded-xl placeholder-slate-500 focus:outline-none focus:ring-2 transition duration-200 sm:text-sm"
    if resource.errors[field].any?
      "#{base_classes} border-red-500 focus:ring-red-500 focus:border-red-500"
    else
      "#{base_classes} border-slate-700 focus:ring-blue-500 focus:border-blue-500"
    end
  end
%>

<div class="min-h-screen w-full flex items-center justify-center bg-slate-900 px-4">
  <div class="max-w-md w-full bg-slate-800 p-10 rounded-3xl shadow-2xl border border-slate-700">
    
    <h2 class="text-3xl font-extrabold text-white text-center mb-10 tracking-tight">
      <%= t('devise.login') %> PokerTracker
    </h2>
 
    <% if flash[:alert] %>
      <div class="mb-6 p-3 rounded-xl bg-red-500/10 border border-red-500/50 text-red-500 text-xs text-center">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      
      <div class="space-y-1">
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "Email", 
            class: login_input_class(:email) %>
        <% if resource.errors[:email].any? %>
          <p class="text-[11px] text-red-500 italic px-1"><%= resource.errors[:email].first %></p>
        <% end %>
      </div>

      <div class="space-y-1">
        <%= f.password_field :password, autocomplete: "current-password", placeholder: t('devise.password') , 
            class: login_input_class(:password) %>
        <% if resource.errors[:password].any? %>
          <p class="text-[11px] text-red-500 italic px-1"><%= resource.errors[:password].first %></p>
        <% end %>
      </div>

      <div class="flex items-center justify-between">
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-slate-700 rounded bg-slate-900 cursor-pointer" %>
            <%= f.label :remember_me, t('devise.remember_me'), class: "ml-2 block text-sm text-slate-400 cursor-pointer" %>
          </div>
        <% end %>
      </div>

      <div class="pt-2">
        <%= f.submit t('devise.loginn') , 
            class: "w-full flex justify-center py-3.5 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition duration-200 cursor-pointer shadow-lg shadow-blue-900/40" %>
      </div>
    <% end %>

    <div class="text-center mt-10 text-sm text-slate-400">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>